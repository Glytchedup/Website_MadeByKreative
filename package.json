{
  "name": "madebykreative",
  "version": "0.1.0",
  "private": true,
  "description": "MadeByKreative — handmade fabric goods storefront with two-way Etsy inventory sync",
  "engines": {
    "node": ">=18.18.0 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "etsy:sync": "tsx --env-file=.env scripts/run-sync.ts",
    "smoke": "tsx --env-file=.env scripts/smoke-test.ts",
    "check:secrets": "bash scripts/check-secrets.sh"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.3.1",
    "clsx": "2.1.1",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "4.1.2",
    "stripe": "17.5.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "6.3.1",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
