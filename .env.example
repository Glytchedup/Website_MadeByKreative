# ===========================================================================
# MadeByKreative — environment variables
# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# The site runs fully WITHOUT Stripe/Etsy/email configured (degrades gracefully),
# so you can `npm run dev` immediately after `cp .env.example .env`.
# ===========================================================================

# ---- Database (Postgres) ---------------------------------------------------
# Postgres for both local dev and production (Neon free tier works great).
#   DATABASE_URL          = pooled (pgbouncer) connection, used at runtime
#   DATABASE_URL_UNPOOLED = direct connection, used for migrations / db push
# On Vercel + Neon these are provided by the integration; locally paste them from
# the Neon dashboard. Example shape:
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- Site ------------------------------------------------------------------
# Public base URL (no trailing slash). Used for SEO canonical URLs, OG tags,
# sitemap, Stripe redirect URLs, and the Etsy OAuth callback.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="MadeByKreative"

# ---- Admin auth ------------------------------------------------------------
# Simple single-user admin login for the maker. Set a strong password.
ADMIN_PASSWORD="change-me-please"
# Random secret used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# ---- Stripe ----------------------------------------------------------------
# From https://dashboard.stripe.com/apikeys . Use test keys (sk_test_/pk_test_)
# while developing. Leave blank to run the store in "preview" mode (no real
# checkout). See README for the full walkthrough.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From the Stripe CLI (`stripe listen`) or the dashboard webhook settings.
STRIPE_WEBHOOK_SECRET=""

# ---- Etsy Open API v3 ------------------------------------------------------
# Register an app at https://www.etsy.com/developers/your-apps (see README).
# Required scopes: listings_r listings_w transactions_r shops_r
# Leave blank to run standalone; the sync dashboard will show "not connected".
ETSY_KEYSTRING=""
ETSY_SHARED_SECRET=""
ETSY_SHOP_ID=""
# Callback must exactly match what you register with Etsy:
#   {NEXT_PUBLIC_SITE_URL}/api/etsy/callback
ETSY_REDIRECT_URI="http://localhost:3000/api/etsy/callback"

# Tunable sync settings (can also be edited in admin Settings).
ETSY_POLL_INTERVAL_SECONDS="150"   # how often the cron polls Etsy (default 2.5 min)
LOW_STOCK_THRESHOLD="3"            # qty <= this triggers JIT live re-check at checkout

# Shared secret protecting the /api/cron/etsy-sync endpoint (Vercel Cron header).
CRON_SECRET="generate-a-long-random-string"

# ---- Email (Resend) --------------------------------------------------------
# https://resend.com . Leave blank to log emails to console instead of sending.
RESEND_API_KEY=""
EMAIL_FROM="MadeByKreative <orders@madebykreative.com>"
# Where contact-form messages and oversell alerts go.
MAKER_NOTIFICATION_EMAIL="kristol@example.com"

# ---- Analytics -------------------------------------------------------------
# GA4 measurement id (G-XXXXXXX). Leave blank to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
